            {
              "type": "text",
              "id": "Hjael",
              "name": "Descricao",
              "fill": "$text-tertiary",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "Existem dois tipos principais desse exame:\n\n• Papanicolau: É o mais comum. Ele procura por pequenas alterações nas células do útero.\n• DNA de HPV: É um exame mais moderno. Ele procura diretamente pelo vírus que pode causar essas alterações.",
              "lineHeight": 1.5,
              "textAlign": "center",
              "fontFamily": "Inter",
              "fontSize": 16,
              "fontWeight": "normal"
            }
